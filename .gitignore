*.py[cod]
*.pyo
*.pyd
*.so

# Virtual Environments
venv/
env/
.venv/

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage
htmlcov/
.tox/
.nox/
.coverage
.cache
nosetests.xml
coverage.xml

# Jupyter Notebook
.ipynb_checkpoints/

# MyPy
.mypy_cache/

# Environment variables
.env
.env.*

# ---- IDE ----
.vscode/
.idea/
*.swp
*.swo
*~

# ---- OS ----
.DS_Store
Thumbs.db

